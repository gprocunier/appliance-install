# Copy this file to config/operators.env when IBM Cloud Pak operators are part
# of the workshop build. Keep real registry credentials in the pull secret
# referenced by APPLIANCE_PULL_SECRET_FILE.

#### These values extend the default operator content with IBM catalog content

_OPERATOR_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Start from the default workshop operator set and append IBM examples.
# shellcheck disable=SC1091
source "${_OPERATOR_CONFIG_DIR}/operators.env.example"

unset _OPERATOR_CONFIG_DIR

# Replace the catalog tag, package names, and channels with values from the IBM
# Cloud Pak release documentation for the content being demonstrated.
APPLIANCE_OPERATOR_PACKAGES+=(
    "icr.io/cpopen/ibm-operator-catalog:replace-with-catalog-tag|ibm-example-operator|replace-with-channel"
    "icr.io/cpopen/ibm-operator-catalog:replace-with-catalog-tag|ibm-example-dependency-operator|replace-with-channel"
)
