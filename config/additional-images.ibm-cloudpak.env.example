# Copy this file to config/additional-images.env when IBM Cloud Pak images must
# be mirrored into appliance.raw outside of operator catalog mirroring.

#### These values define IBM private registry images mirrored as additionalImages

# IBM Entitled Registry content under cp.icr.io requires auth in the pull secret
# referenced by APPLIANCE_PULL_SECRET_FILE.
APPLIANCE_ADDITIONAL_IMAGES=(
    "cp.icr.io/cp/example-cloudpak-operand:replace-with-tag"
    "cp.icr.io/cp/example-cloudpak-dependency@sha256:replace-with-digest"
)

# Use an ignored one-image-per-line file for large IBM generated image lists.
APPLIANCE_ADDITIONAL_IMAGES_FILE="config/cloudpak.images"
