# Copy this file to config/appliance.env and adjust it for the target lab.

#### These values define the OpenShift appliance content build

APPLIANCE_OCP_VERSION="4.21"
APPLIANCE_OCP_CHANNEL="stable"
APPLIANCE_OCP_CPU_ARCHITECTURE="x86_64"
APPLIANCE_IMAGE_DISK_SIZE_GB="200"
APPLIANCE_BUILDER_IMAGE="quay.io/edge-infrastructure/openshift-appliance:latest"

#### These values identify local-only credentials and access material

# Keep the real pull secret only in ignored local files.
APPLIANCE_PULL_SECRET_FILE="${HOME}/pull-secret.txt"

# The core password is converted into the appliance image for console access.
APPLIANCE_CORE_PASSWORD="replace-with-core-console-password"

# The public key is added to the appliance and generated cluster config.
APPLIANCE_CORE_SSH_PUBLIC_KEY_FILE="${APPLIANCE_FOUNDRY_SSH_PUBLIC_KEY_FILE}"

#### These values define foundry build directories

APPLIANCE_ASSETS_DIR="/srv/appliance/assets"
APPLIANCE_CLUSTER_CONFIG_DIR="/srv/appliance/cluster-config"

#### These values define the OpenShift cluster identity

APPLIANCE_CLUSTER_NAME="appliance"
APPLIANCE_BASE_DOMAIN="workshop.lan"
APPLIANCE_MACHINE_NETWORK_CIDR="172.16.10.0/24"
APPLIANCE_RENDEZVOUS_IP="172.16.10.11"
APPLIANCE_NODE_INTERFACE="enp1s0"
APPLIANCE_AGENT_NTP_SOURCE="${APPLIANCE_FOUNDRY_APPLIANCE_IP}"

#### These values define where OpenShift VM disks live on the virt host

APPLIANCE_OCP_IMAGE_DIR="/home/libvirt/images/appliance-install"
APPLIANCE_OCP_OS_VARIANT="fedora-coreos-stable"

#### These values control long-running build behavior

APPLIANCE_CLEAN_BEFORE_BUILD="false"
APPLIANCE_BUILD_LOG_LEVEL="info"
APPLIANCE_REFRESH_BASE_IMAGE="false"
APPLIANCE_PRUNE_FOUNDRY_BUILD_CACHE_BEFORE_COPY="true"
APPLIANCE_KEEP_HOST_RAW_IMAGE="false"
