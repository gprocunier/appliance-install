# Copy this file to config/operators.env and adjust it for the target lab.

#### These values define the operator content mirrored into appliance.raw

# Entries may use either:
#   "package|channel"
#   "catalog-image|package|channel"
#
# When the catalog is omitted, APPLIANCE_OPERATOR_CATALOG is used.
# Private catalog images require matching registry auth in APPLIANCE_PULL_SECRET_FILE.
APPLIANCE_OPERATOR_CATALOG="registry.redhat.io/redhat/redhat-operator-index:v${APPLIANCE_OCP_VERSION:-4.21}"

APPLIANCE_OPERATOR_PACKAGES=(
    "kubevirt-hyperconverged|stable"
    "kubernetes-nmstate-operator|stable"
    "openshift-cert-manager-operator|stable-v1"
    "netobserv-operator|stable"
    "web-terminal|fast"
    "quay-operator|stable-3.16"
    "odf-operator|stable-4.21"
    "ocs-operator|stable-4.21"
    "mcg-operator|stable-4.21"
    "odf-csi-addons-operator|stable-4.21"
    "odf-dependencies|stable-4.21"
    "odf-external-snapshotter-operator|stable-4.21"
    "odf-prometheus-operator|stable-4.21"
    "ocs-client-operator|stable-4.21"
    "recipe|stable-4.21"
    "rook-ceph-operator|stable-4.21"
    "cephcsi-operator|stable-4.21"
    # "icr.io/cpopen/ibm-operator-catalog:replace-with-tag|ibm-example-operator|replace-with-channel"
)
