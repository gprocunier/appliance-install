# Copy this file to config/additional-images.env and adjust it for the target lab.

#### These values define non-operator images mirrored into appliance.raw

# Private registry credentials must be present in the pull secret referenced by
# APPLIANCE_PULL_SECRET_FILE in config/appliance.env.
#
# IBM Cloud Pak content commonly needs IBM Entitled Registry auth for cp.icr.io.
# Some catalog or public content may come from icr.io or icr.io/cpopen.
#
# Entries must be complete image references. Use tags or digests.
APPLIANCE_ADDITIONAL_IMAGES=(
    # "cp.icr.io/cp/example-cloudpak-image:tag"
    # "icr.io/cpopen/example-public-image@sha256:replace-with-digest"
)

# Optional: put a large one-image-per-line list in an ignored local
# config/*.images file and reference it here. Blank lines and lines beginning
# with # are skipped.
APPLIANCE_ADDITIONAL_IMAGES_FILE=""
