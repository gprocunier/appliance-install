# Copy this file to config/foundry-standalone.env and adjust it for the target host.

#### These values identify the standalone RHEL 10.x foundry host

APPLIANCE_STANDALONE_HOST="replace-with-rhel10-host-address"
APPLIANCE_STANDALONE_USER="root"
APPLIANCE_STANDALONE_SSH_KEY="${HOME}/.ssh/id_ed25519"

# This public key is used by config/appliance.env when the default example value
# for APPLIANCE_CORE_SSH_PUBLIC_KEY_FILE is kept.
APPLIANCE_STANDALONE_CORE_SSH_PUBLIC_KEY_FILE="${APPLIANCE_STANDALONE_SSH_KEY}.pub"

#### These values describe package repository defaults for the standalone host

RHSM_BASEOS_REPO="rhel-10-for-x86_64-baseos-rpms"
RHSM_APPSTREAM_REPO="rhel-10-for-x86_64-appstream-rpms"
RHSM_CODEREADY_REPO="codeready-builder-for-rhel-10-x86_64-rpms"

#### These values control local artifact retrieval

APPLIANCE_STANDALONE_LOCAL_OUTPUT_DIR="work/foundry-standalone"
