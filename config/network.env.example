# Copy this file to config/network.env and adjust it for the target lab.

#### These values define the OVS-only appliance lab switch

APPLIANCE_OVS_BRIDGE="lab-switch"
APPLIANCE_LIBVIRT_NETWORK="lab-switch"
APPLIANCE_ENABLE_HOST_IPV4_FORWARDING="true"

#### These values define the OpenShift machine network

APPLIANCE_MACHINE_PORT="app-machine"
APPLIANCE_MACHINE_PORTGROUP="machine-vlan200"
APPLIANCE_MACHINE_VLAN_ID="200"
APPLIANCE_MACHINE_GATEWAY_CIDR="172.16.10.1/24"

#### These values are reserved for later OVS-only cluster networks

APPLIANCE_STORAGE_PORT="app-storage"
APPLIANCE_STORAGE_PORTGROUP="storage-vlan201"
APPLIANCE_STORAGE_VLAN_ID="201"
APPLIANCE_STORAGE_GATEWAY_CIDR=""

APPLIANCE_MIGRATION_PORT="app-migrate"
APPLIANCE_MIGRATION_PORTGROUP="migration-vlan202"
APPLIANCE_MIGRATION_VLAN_ID="202"
APPLIANCE_MIGRATION_GATEWAY_CIDR=""
