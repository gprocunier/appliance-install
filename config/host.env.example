# Copy this file to config/host.env and adjust it for the target host.

#### These values identify the on-prem virtualization host

APPLIANCE_HOST="172.18.0.239"
APPLIANCE_HOST_USER="root"
APPLIANCE_HOST_SSH_KEY="${HOME}/.ssh/id_ed25519"

#### These values describe the host package/repository defaults

RHSM_BASEOS_REPO="rhel-10-for-x86_64-baseos-rpms"
RHSM_APPSTREAM_REPO="rhel-10-for-x86_64-appstream-rpms"
RHSM_FAST_DATAPATH_REPO="fast-datapath-for-rhel-10-x86_64-rpms"
RHSM_CODEREADY_REPO="codeready-builder-for-rhel-10-x86_64-rpms"

APPLIANCE_OVS_PACKAGE="openvswitch3.6"
