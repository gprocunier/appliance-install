# Copy this file to config/foundry.env and adjust it for the target lab.

#### These values define the foundry virtual machine

APPLIANCE_FOUNDRY_NAME="foundry"
APPLIANCE_FOUNDRY_SHORT_HOSTNAME="foundry"
APPLIANCE_FOUNDRY_HOSTNAME="foundry.appliance.workshop.lan"
APPLIANCE_FOUNDRY_USER="appliance"

APPLIANCE_FOUNDRY_MEMORY_MB="32768"
APPLIANCE_FOUNDRY_VCPUS="8"
APPLIANCE_FOUNDRY_DISK_SIZE_GB="300"
APPLIANCE_FOUNDRY_OS_VARIANT="rhel10.1"

#### These values identify the RHEL cloud image already staged on the virt host

APPLIANCE_FOUNDRY_IMAGE_DIR="/var/lib/libvirt/images"
APPLIANCE_FOUNDRY_BASE_IMAGE="/var/lib/libvirt/images/replace-with-rhel-cloud-image.qcow2"

#### These values define foundry SSH access

APPLIANCE_FOUNDRY_SSH_KEY="${APPLIANCE_HOST_SSH_KEY}"
APPLIANCE_FOUNDRY_SSH_PUBLIC_KEY_FILE="${APPLIANCE_FOUNDRY_SSH_KEY}.pub"

#### These values define foundry VM networking

APPLIANCE_FOUNDRY_UPSTREAM_NETWORK="default"
APPLIANCE_FOUNDRY_UPSTREAM_MAC="52:54:00:10:10:10"
APPLIANCE_FOUNDRY_APPLIANCE_MAC="52:54:00:10:10:11"
APPLIANCE_FOUNDRY_APPLIANCE_IP="172.16.10.10"
APPLIANCE_FOUNDRY_APPLIANCE_PREFIX="24"
APPLIANCE_FOUNDRY_APPLIANCE_CIDR="172.16.10.0/24"

#### These values define appliance DNS records served by foundry

APPLIANCE_CLUSTER_DOMAIN="appliance.workshop.lan"
APPLIANCE_IDM_REALM="APPLIANCE.WORKSHOP.LAN"
APPLIANCE_IDM_DIRECTORY_MANAGER_PASSWORD="replace-with-directory-manager-password"
APPLIANCE_IDM_ADMIN_PASSWORD="replace-with-idm-admin-password"

APPLIANCE_MIRROR_REGISTRY_NAME="mirror-registry"
APPLIANCE_API_IP="172.16.10.5"
APPLIANCE_INGRESS_IP="172.16.10.7"

APPLIANCE_NODE_1_NAME="ocp-01"
APPLIANCE_NODE_1_IP="172.16.10.11"
APPLIANCE_NODE_2_NAME="ocp-02"
APPLIANCE_NODE_2_IP="172.16.10.12"
APPLIANCE_NODE_3_NAME="ocp-03"
APPLIANCE_NODE_3_IP="172.16.10.13"

#### These values define appliance-builder workspace defaults

APPLIANCE_FOUNDRY_ASSETS_DIR="/srv/appliance/assets"
APPLIANCE_FOUNDRY_HTTP_ROOT="/srv/appliance"
APPLIANCE_BUILDER_IMAGE="catalog.redhat.com/software/containers/assisted/agentpreinstall-image-builder-rhel9/65a55174031d94dbea7f2e00"
